  "publicApiSurface": [
    "useLatestNews(limit)",
    "useArticle(blobId)",
    "useArticleComments(blobId)",
    "usePostComment()",
    "createTipArticleTransaction(blobId, amount)",
    "createPostCommentTransaction(blobId, text)",
    "createTipCommentTransaction(commentId, amount)",
